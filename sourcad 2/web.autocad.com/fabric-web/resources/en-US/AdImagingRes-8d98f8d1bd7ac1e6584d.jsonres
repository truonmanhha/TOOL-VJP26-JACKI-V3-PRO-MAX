    "10100": "Macintosh PICT",
    "10101": "The PICT format is the Macintosh's native drawing format (similar to WMF on Windows).",
    "10102": "Copyright (c) 1995-1997 by Autodesk, Inc. Some parts Copyright 1989,1992,1993 George Phillips.",
    "10103": "pct",
    "10104": "pict",
    "11100": "Portable Network Graphics file",
    "11101": "PNG is an extensible file format for the lossless, portable, well-compressed storage of raster images. PNG provides a patent-free replacement for GIF and can also replace many common uses of TIFF. Indexed-color, grayscale, and truecolor images are supported, plus an optional alpha channel for transparency. Sample depths range from 1 to 16 bits.",
    "11102": "png",
    "11103": "Transparency",
    "11104": "Specifies that the image uses  transparency.True color images (RGB)  this can be a full alpha channel. Other images use either alpha values associated with palette entries (for indexed-color images) or a single transparent color (for grayscale).",
    "11105": "Gamma",
    "11106": "PNG images can store the power function relating the desired display output with the image samples. ",
    "11107": "Density",
    "11108": "PNG can store the intended pixel size or aspect ratio for display of the image.",
    "11109": "PNG_IDS_PROP_COMMENT_KEYWORD_CREATIONTIME_DESC",
    "11111": "Image Scale",
    "11112": "The scale used to place an image into an application coordinate system.",
    "11113": "Horizontal Axis Scale",
    "11114": "The width of a pixel along the horizontal axis.",
    "11115": "Vertical Axis scale",
    "11116": "The height of a pixel along the vertical axis.",
    "11117": "Meters",
    "11118": "The scales are expressed in meters.",
    "11119": "Radians",
    "11120": "The scales are expressed in radians.",
    "11121": "Scale Units",
    "11122": "The units of the horizontal and vertical scale factors.",
    "11123": "Image Offset",
    "11124": "The position on a printed page at which the image should be output when printed alone. It can also be used to define the image's location with respect to a larger screen or other application-specific coordinate system.",
    "11125": "Horizontal Offset",
    "11126": "The horizontal offset from the left side of the page.",
    "11127": "Vertical Offset",
    "11128": "The vertical offset from the top of the page.",
    "11129": "Offset Units",
    "11130": "The units of the horizontal and vertical offsets.",
    "11131": "Pixels",
    "11132": "The offsets are expressed in pixels.",
    "11133": "Micrometer",
    "11134": "The offsets are expressed in micrometers (Microns).",
    "11135": "Background color",
    "11136": "PNG images can store a default background color to present the image against. Note that viewers are not bound to honor this color; a viewer can choose to use a different background. ",
    "11137": "sRgb Rendering Intent",
    "11138": "PNG and store  sRGB intent information. If present, the image samples conform to the sRGB color space (sRGB), and should be displayed using the specified rendering intent as defined by the International Color Consortium (ICC).",
    "11139": "Title",
    "11140": "A short (one line) title or caption for the image.",
    "11141": "Author",
    "11142": "The name of the image's creator.",
    "11143": "Description",
    "11144": "Description of the image's contents. ",
    "11145": "Copyright",
    "11146": "Copyright notice.",
    "11147": "Creation time",
    "11148": "The time of the original image creation.",
    "11149": "Software",
    "11150": "The software used to create the image.",
    "11151": "Disclaimer",
    "11152": "Legal disclaimer.",
    "11153": "Warning",
    "11154": "Warning regarding the nature of the image's content.",
    "11155": "Source",
    "11156": "The name or description of the device used to create the image.",
    "11157": "Comment",
    "11158": "Miscellaneous comment.",
    "11159": "Perceptual",
    "11160": "Perceptual intent is for images preferring good adaptation to the output device gamut at the expense of colorimetric accuracy, like photographs.",
    "11161": "Relative Colormetric",
    "11162": "Relative colorimetric intent is for images requiring color appearance matching (relative to the output device white point), like logos. ",
    "11163": "Saturation",
    "11164": "Saturation intent is for images preferring preservation of saturation at the expense of hue and lightness, like charts and graphs.",
    "11165": "Absolute Colormetric",
    "11166": "Absolute colorimetric intent is for images requiring preservation of absolute colorimetry, like proofs (previews of images destined for a different output device).",
    "11167": "Histogram",
    "11168": "PNG can store a Histogram which gives the approximate usage frequency of each color in the color palette. Histograms can be encoded with a paletted image. If a viewer is unable to provide all the colors listed in the palette, the histogram may help it decide how to choose a subset of the colors for display. ",
    "11169": "Significant Bits",
    "11170": "The number of significant bits per pixel for grayscale images.",
    "11171": "Unknown",
    "11172": "The scales are not expressed in a known unit system.",
    "11173": "Compression",
    "11174": "PNG supports various lossless compression levels that vary from no compression to highly compressed. Various levels are a trade off between time and amount of compression.",
    "11175": "Uncompressed",
    "11176": "No compression is used",
    "11177": "Low",
    "11178": "A minimum amount of compression is done in favor of speed",
    "11179": "Medium",
    "11180": "A balance that favors speed over compression",
    "11181": "Normal",
    "11182": "A good balance between compression level and speed",
    "11183": "High",
    "11184": "The maximum amount of compression is achieved by sacrificing speed.",
    "11185": "Interlace",
    "11186": "PNG can interlace the raster data. This is most commonly done for images to be displayed online.",
    "27100": "psd",
    "27102": "Adobe Photoshop Format",
    "27103": "Adobe Photoshop format. This is a limited reader.",
    "27104": "Photoshop reader by Autodesk, Inc.",
    "23100": "QuickBird Tagged Image File Format",
    "23101": "TIFF is a tag-based file format for storing and interchanging raster images. QBTIFF is a special case for QuickBird TIFF files.",
    "23102": "COPYRIGHT 2005 DigitalGlobe, Inc., Longmont CO USA 80503",
    "23103": "tif",
    "23104": "tiff",
    "23105": "Compression",
    "23106": "QBTIFF images only contain uncomperssed data according to the specification.",
    "23107": "Uncompressed",
    "23108": "No compression is used.",
    "23109": "CCITT RLE",
    "23110": "CCITT modified Huffman Run Length Encoding.",
    "23111": "CCITT RLEW",
    "23112": "CCITT modified Huffman Run Length Encoding with word alignment.",
    "23113": "CCITT (Fax) Group 3",
    "23114": "CCITT Group 3 1-D Modified Huffman RLE Compression.",
    "23115": "CCITT (Fax) Group 4",
    "23116": "CCITT Group 4 2-D Modified Huffman RLE Compression.",
    "23117": "LZW",
    "23118": "Lempel-Ziv  & Welch.",
    "23119": "Packbits",
    "23120": "Apple Macintosh (packbits) Run Length Encoding",
    "23123": "JPEG",
    "23124": "JPEG Discrete Cosine Transform compression",
    "23125": "Data Organization",
    "23126": "Specifies how the image pixels are organized within the file.",
    "23127": "Image Density",
    "23128": "A pair of floating point values describing the size of a pel in the X and Y dimensions as a fraction of a unit.",
    "23129": "Frame Association",
    "23130": "This frame has a relationship to another frame present in this image file.",
    "23131": "Transparency",
    "23132": "There is an extra eight bit sample that represents associated alpha transparency.",
    "23133": "Photometric Interpretation",
    "23134": "Determines how to interpret bitonal and grayscale values.",
    "23135": "Minimum is white.",
    "23136": "The lowest data value represents white.",
    "23137": "Minimum is black.",
    "23138": "The lowest data value represents black.",
    "23139": "Fill Order",
    "23140": "The TIFF specification recommends that the default (MSB to LSB) fill order be changed only in special-purpose applications.",
    "23141": "MSB to LSB",
    "23143": "LSB to MSB",
    "23144": "Pixels are arranged within a byte such that pixels with lower column values are stored in the lower-order bits of the byte. Not all readers need support this fill order.",
    "23145": "Gray Response Curve",
