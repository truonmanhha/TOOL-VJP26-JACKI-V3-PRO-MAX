2493:-  /**
2494:-   * Sample a B-spline curve from control points, degree, and optional knot vector.
2495:-   * Uses Cox-de Boor recursion to evaluate basis functions.
2496:-   * Returns numSamples evenly-spaced points along the curve.
2497:-   */
2498:-  private sampleBSpline(
2499:-    controlPoints: { x: number; y: number }[],
2500:-    degree: number,
2501:-    knots: number[] | undefined,
2502:-    numSamples: number
2503:-  ): { x: number; y: number }[] {
2504:-    const n = controlPoints.length;
2505:-    const p = Math.min(degree, n - 1); // clamp degree
2506:-
2507:-    // Generate uniform knot vector if not provided
2508:-    let knotVec: number[];
2509:-    if (knots && knots.length === n + p + 1) {
2510:-      knotVec = knots;
2511:-    } else {
2512:-      // Clamped uniform: p+1 zeros, interior knots, p+1 ones
2513:-      knotVec = [];
2514:-      const m = n + p + 1;
2515:-      for (let i = 0; i < m; i++) {
2516:-        if (i <= p) knotVec.push(0);
2517:-        else if (i >= m - p - 1) knotVec.push(1);
2518:-        else knotVec.push((i - p) / (n - p));
2519:-      }
2520:-    }
2521:-
2522:-    // Cox-de Boor basis function evaluation
2523:-    const basis = (i: number, deg: number, t: number): number => {
2524:-      if (deg === 0) {
2525:-        return (t >= knotVec[i] && t < knotVec[i + 1]) ? 1 : 0;
2526:-      }
2527:-      let left = 0, right = 0;
2528:-      const dLeft = knotVec[i + deg] - knotVec[i];
2529:-      const dRight = knotVec[i + deg + 1] - knotVec[i + 1];
2530:-      if (dLeft > 1e-10) left = ((t - knotVec[i]) / dLeft) * basis(i, deg - 1, t);
2531:-      if (dRight > 1e-10) right = ((knotVec[i + deg + 1] - t) / dRight) * basis(i + 1, deg - 1, t);
2532:-      return left + right;
2533:-    };
2534:-
2535:-    // Determine parameter range from knot vector
2536:-    const tMin = knotVec[p];
2537:-    const tMax = knotVec[n]; // = knotVec[knotVec.length - p - 1]
2538:-    const points: { x: number; y: number }[] = [];
2539:-
2540:-    for (let s = 0; s <= numSamples; s++) {
2541:-      const t = tMin + (s / numSamples) * (tMax - tMin);
2542:-      // Clamp last sample to just below tMax to avoid basis edge case
2543:-      const tEval = s === numSamples ? tMax - 1e-10 : t;
2544:-      let x = 0, y = 0;
2545:-      for (let i = 0; i < n; i++) {
2546:-        const b = basis(i, p, tEval);
2547:-        x += b * controlPoints[i].x;
2548:-        y += b * controlPoints[i].y;
2549:-      }
2550:-      points.push({ x, y });
2551:-    }
2552:-
2553:-    // Ensure last point is exactly the last control point (clamped spline property)
2554:-    if (points.length > 0) {
2555:-      points[points.length - 1] = {
2556:-        x: controlPoints[n - 1].x,
2557:-        y: controlPoints[n - 1].y
2558:-      };
2559:-    }
2560:-
2561:-    return points;
2562:-  }
