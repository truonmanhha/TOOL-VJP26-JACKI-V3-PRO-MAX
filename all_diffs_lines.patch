1942:-  /**
1943:-   * Convert DWG file to DXF using external converters (3-tier fallback).
1944:-   * Follows FreeCAD pattern: DWG -> DXF -> existing DXF parser
1945:-   * 
1946:-   * Fallback strategy (external converters):
1947:-   * 1. LibreDWG converter: dwg2dxf <input.dwg> -o <output.dxf>
1948:-   * 2. ODA/Teigha FileConverter: ODAFileConverter <indir> <outdir> ACAD2000 DXF 0 1 <basename>
1949:-   * 3. QCAD dwg2dwg converter: dwg2dwg -f -o <output.dxf> <input.dwg>
1950:-   * 4. If all external tools unavailable: fallback to LibreDwg WASM (browser-compatible)
1951:-   * 
1952:-   * Why this pattern:
1953:-   * - External converters understand all DWG versions (2000, 2004, 2010, 2018, etc.)
1954:-   * - Parsing via existing DXF logic reduces bugs
1955:-   * - Production tools (AutoCAD, FreeCAD) use same pattern
1956:-   * - WASM is fallback for browser-only environments (no subprocess access)
1957:-   * 
1958:-   * @param dwgFile - DWG file to convert
1959:-   * @param layerId - optional layer to assign to imported entities
1960:-   * @returns CadEntity[] (via external converter -> DXF parse, or empty if conversion fails)
1961:-   */
1962:-  private async convertDwgToDxf(dwgFile: File, layerId?: string): Promise<CadEntity[]> {
1963:-    // Try Python backend API first (supports DWG via LibreDWG CLI)
1964:-    try {
1965:-      const apiResponse = await uploadDxf(dwgFile);
1966:-      if (apiResponse.success && apiResponse.entities.length > 0) {
1967:-        console.log(`📄 DWG parsed via backend: ${apiResponse.entities.length} entities`);
1968:-        return apiResponse.entities.map(e => this._apiToCadEntity(e, layerId));
1969:-      }
1970:-    } catch (apiError) {
1971:-      console.warn('[NestingAX DWG] Backend unavailable, using fallback:', apiError);
1972:-    }
1973:-
1974:-    // Fallback: Try Express DWG->DXF converter
1975:-    try {
1976:-      const formData = new FormData();
1977:-      formData.append('file', dwgFile);
1978:-      const response = await fetch('/api/convert-dwg-to-dxf', {
1979:-        method: 'POST',
1980:-        body: formData,
1981:-        headers: {
1982:-          'Accept': 'application/json'
1983:-        }
1984:-      });
1985:-      if (response.ok) {
1986:-        const result = await response.json();
1987:-        if (result.dxfContent) {
1988:-          console.log('🔄 Converting DWG to DXF via LibreDWG/ODA/QCAD converter');
1989:-          const dxfFile = new File([result.dxfContent], dwgFile.name.replace(/\.dwg$/i, '.dxf'), { type: 'text/plain' });
1990:-          const entities = await this._parseDxfFileFallback(dxfFile, layerId);
1991:-          console.log(`📄 DXF parsed from DWG: ${entities.length} entities`);
1992:-          return entities;
1993:-        }
1994:-      }
